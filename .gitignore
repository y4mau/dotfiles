# Sensitive files - DO NOT COMMIT
*.key
*.pem
*.p12
*.pfx
*.cer
*.crt
*secret*
*password*
*credential*
*token*
*.env
.envrc

# AWS credentials
.aws/
.boto

# SSH keys
.ssh/

# Cloud provider configs with credentials
.azure/
.gcp/

# Shell history (may contain sensitive commands)
.*_history
.zsh_history
.bash_history
.psql_history
.irb_history
.python_history

# API keys and tokens
.claude.json*
.openai/
.anthropic/

# Claude Code sensitive files
claude/_settings.json
claude/settings.local.json
claude/credentials/
claude/debug/
claude/file-history/
claude/history.jsonl
claude/instructions/
claude/memories/
claude/projects/
claude/session-env/
claude/shell-snapshots/
claude/stats-cache.json
claude/statsig/
claude/telemetry/
claude/todos/
claude/plans/
claude/plugins/
claude/ide/

# Codex CLI sensitive files
codex/auth.json
codex/history.jsonl
codex/sessions/
codex/log/
codex/version.json
codex/internal_storage.json

# Fish runtime files
fish/fish_history
fish/fish_variables
fish/fishd.*

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Cache and temp files
*.cache
*.log
*.tmp
.cache/
.temp/

# Machine-specific local overrides
git/.gitconfig.local

# Local environment
.local/
.npm/
.nvm/
.rbenv/
.pyenv/
node_modules/

# IDE specific (may contain project-specific settings)
.vscode/settings.json
.idea/*

# Database
*.sqlite
*.db
