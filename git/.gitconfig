[user]
	# NOTE: Replace with your own name and email
	name = Your Name
	email = your.email@example.com
[include]
	path = ~/.gitconfig.local
[pager]
	log = less
	branch = cat
	config = less
[core]
	editor = code --wait
[init]
	defaultBranch = main
[diff]
	tool = vscode
[difftool "vscode"]
	cmd = code --wait --diff $LOCAL $REMOTE
[difftool]
	prompt = false
